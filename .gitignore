# ========================================
# 众生界项目 - Git推送配置
# ========================================
# 
# master分支推送内容：
# - 项目代码（core/、modules/、tools/、tests/）
# - Skills源码（skills/）
# - 案例库索引和脚本（.case-library/*.json、scripts/）
# - 配置模板（config.example.json）
# - 向量库代码（.vectorstore/core/）
# - 文档（docs/、README.md）
# 
# 不推送（需用户自行构建）：
# - 技法库数据（创作技法/*.md）
# - 小说设定（设定/*.md）
# - 案例数据（.case-library/cases/*.json/*.txt）
# - 向量数据（Qdrant本地数据，约20G）
# - 用户创作内容（正文/、章节大纲/、总大纲.md）
# 
# 作者：coffeeliuwei
# 版本：v15.0
# 最后更新：2026-04-14
# ========================================

# ========================================
# 用户自建内容 - 不推送
# ========================================

创作技法/**/*.md
创作技法/**/*.txt
设定/
正文/
章节大纲/
章节经验日志/
写作标准积累/
评估报告/
/总大纲.md

# 案例库数据（太大，仅推送索引和脚本）
.case-library/cases/

# ========================================
# 运行时状态 - 本地私有
# ========================================

.state/
.opencode/
.seren/
.seren/
.agents/
.project_memory/

# Qdrant本地数据（约20G）
.vectorstore/qdrant/
.vectorstore/qdrant_docker/

# 日志和缓存
logs/
.cache/
*.log
*.cache

# ========================================
# 配置文件 - 含本地路径
# ========================================

config.json
config.local.json
system_config.json
.env
*.env

# ========================================
# IDE 和编辑器
# ========================================

.vscode/
.idea/
*.swp
*.swo
*~

# ========================================
# OS 文件
# ========================================

.DS_Store
Thumbs.db
Desktop.ini

# ========================================
# Python
# ========================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ========================================
# 临时文件
# ========================================

*.tmp
*.bak
*.backup
*.old
*.orig

# 根目录临时测试文件
/test_*.py
/test_*.txt
/temp_*.txt
/verify_*.py
/fix_*.py

# 测试数据库
.test_chroma/
.test_qdrant/

# ========================================
# 测试覆盖率
# ========================================

htmlcov/
.tox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ========================================
# 向量库缓存
# ========================================

.vectorstore/__pycache__/
.vectorstore/*/__pycache__/
.vectorstore/*/segments/
.vectorstore/*/temp_segments/
*.pickle
*.index

# ========================================
# 数据库文件
# ========================================

*.sqlite
*.sqlite3

# ========================================
# 归档文件
# ========================================

archived/
.archived/
存档/