  "云溪诗词能力配置": {
    "emotion_core_method": {
      "description": "情感内核分析法",
      "steps": [
        "1. 提取场景核心情感（不是表面情感）",
        "2. 确定情感内核的哲学层面",
        "3. 选择契合情感内核的意象",
        "4. 构建意象之间的内在关联",
        "5. 以情感内核统领全诗"
      ]
    },
    "imagery_selection": {
      "description": "意象选择原则",
      "rules": [
        "意象必须契合情感内核",
        "意象之间要有内在关联（不是简单堆砌）",
        "众生界场景必须使用世界观特色意象",
        "意象要有层次感（从具体到抽象）"
      ]
    },
    "structure_guidelines": {
      "律诗": "七言或五言，起承转合完整",
      "绝句": "四句，意象集中，情感饱满",
      "词": "长短句，节奏灵活，情感层叠"
    }
  }
