  "诗词触发规则": {
    "phase_3_auto": {
      "description": "Phase 3润色阶段，云溪负责的场景自动触发诗词",
      "trigger_condition": "writer == '云溪' && phase == 3",
      "default_config": {
        "poetry_type": "律诗",
        "imagery_count": 5,
        "examples_count": 3
      }
    },
    "emotion_threshold": {
      "description": "情感阈值触发，当场景情感强度达到阈值时触发诗词",
      "trigger_condition": "emotion_intensity >= 0.8",
      "threshold": 0.8,
      "emotion_types": ["悲壮", "悲凉", "苍凉", "虚无", "哀愁"]
    },
    "world_context_trigger": {
      "description": "众生界特定场景触发",
      "trigger_condition": "world_context == '众生界' && scene_type in ['命运觉悟', '突破挣扎']",
      "mandatory": true
    }
  },
  
